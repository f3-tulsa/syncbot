# Cloud deployment config — copy to .env.deploy.test or .env.deploy.prod.
# Used by ./deploy.sh --env test|prod
#
# For LOCAL DEVELOPMENT, use .env.example instead (cp .env.example .env).
#
# The default path assumes an external database (e.g. TiDB Cloud) with a
# pre-existing app user and schema.  Set DATABASE_USER + DATABASE_PASSWORD
# and the deploy skips DB admin setup entirely.

# Cloud provider — allows ./deploy.sh --env test without specifying a provider.
CLOUD_PROVIDER=aws

# --- Provider: AWS (default) ---
AWS_REGION=us-east-2
STACK_NAME=syncbot-test
BOOTSTRAP_STACK_NAME=syncbot-bootstrap

# --- Provider: GCP (uncomment if using GCP) ---
# GCP_PROJECT_ID=
# GCP_REGION=us-central1
# CLOUD_RUN_IMAGE=

# Slack app credentials
SLACK_SIGNING_SECRET=
SLACK_CLIENT_SECRET=
SLACK_CLIENT_ID=

# Token encryption key (passed as SAM parameter / Terraform variable; not stored in cloud secret managers).
# Leave empty to auto-generate on first deploy (the value is saved back to this file).
DATA_ENCRYPTION_KEY=

# --- Database (external / TiDB default) ---
# When DATABASE_USER and DATABASE_PASSWORD are both set, the deploy assumes
# the user and schema already exist -- no admin credentials or DbSetup needed.
DATABASE_HOST=gateway.tidbcloud.com
DATABASE_PORT=4000
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_SCHEMA=syncbot
DATABASE_ENGINE=mysql
DATABASE_TLS_ENABLED=true

# --- Optional: auto-create DB user/schema (new RDS or first-time setup) ---
# Set these INSTEAD of DATABASE_USER/DATABASE_PASSWORD to have the deploy
# create the app user and schema automatically via the DbSetup custom resource.
# DATABASE_ADMIN_USER=root
# DATABASE_ADMIN_PASSWORD=
# DATABASE_USERNAME_PREFIX=       # TiDB cluster prefix (e.g. abc123)
# DATABASE_APP_USERNAME=          # optional override for generated app username
# DATABASE_CREATE_APP_USER=true
# DATABASE_CREATE_SCHEMA=true

# --- Bootstrap (one-time OIDC + SAM artifact bucket; use ./deploy.sh --env test --bootstrap) ---
# CREATE_OIDC_PROVIDER=true
# DEPLOY_BUCKET_PREFIX=syncbot-deploy

# --- Optional: OIDC deploy role ARN for ./deploy.sh --setup-github ---
# AWS_ROLE_ARN=

# --- Optional: SAM artifact bucket override (bootstrap stack output DeploymentBucketName) ---
# DEPLOYMENT_S3_BUCKET=

# --- Optional: resolve secrets from cloud Secret Manager ---
# Set *_SM_ID to reference an existing SM secret by name/ID.
# The deploy script fetches the value automatically (aws secretsmanager / gcloud secrets).
# Direct values (e.g. SLACK_SIGNING_SECRET=abc) take precedence over _SM_ID refs.
# SLACK_SIGNING_SECRET_SM_ID=syncbot/slack-signing-secret
# SLACK_CLIENT_SECRET_SM_ID=syncbot/slack-client-secret
# DATA_ENCRYPTION_KEY_SM_ID=syncbot/data-encryption-key
# DATABASE_PASSWORD_SM_ID=syncbot/db-password

# --- Optional app settings ---
# LOG_LEVEL=INFO
# REQUIRE_ADMIN=true
# SOFT_DELETE_RETENTION_DAYS=30
# PRIMARY_WORKSPACE=
# ENABLE_DB_RESET=
# SYNCBOT_FEDERATION_ENABLED=false
# SYNCBOT_INSTANCE_ID=
# SYNCBOT_PUBLIC_URL=
# ENABLE_XRAY=false
